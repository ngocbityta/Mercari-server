// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  HV
  GV
}

enum UserStatus {
  ACTIVE
  LOCKED
}

model User {
  id             String          @id @default(uuid()) @db.Uuid
  phonenumber    String          @unique @db.VarChar
  password       String          @db.VarChar
  username       String?         @db.VarChar
  avatar         String?         @db.VarChar
  coverImage     String?         @map("cover_image") @db.VarChar
  description    String?         @db.Text
  role           UserRole
  token          String?         @db.VarChar
  height         String?         @db.VarChar
  status         UserStatus      @default(ACTIVE)
  online         Boolean         @default(false)
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime        @updatedAt @map("updated_at") @db.Timestamptz

  blocks         Block[]         @relation("blocker")
  blockedBy      Block[]         @relation("blocked")
  conversationsA Conversation[]  @relation("partnerA")
  conversationsB Conversation[]  @relation("partnerB")
  sentMessages   Message[]       @relation("sender")
  receivedMessages Message[]     @relation("receiver")
  devices        Device[]
  notifications  Notification[]
  pushSetting    PushSetting?
  posts                Post[]
  comments             Comment[]
  reports              Report[]
  enrollments          Enrollment[]        @relation("student_enrollments")
  teachingEnrollments  Enrollment[]        @relation("teacher_enrollments")
  enrollmentRequests   EnrollmentRequest[] @relation("student_requests")
  receivedEnrollments  EnrollmentRequest[] @relation("teacher_requests")

  @@map("users")
}

model Block {
  blockerId String @map("blocker_id") @db.Uuid
  blockedId String @map("blocked_id") @db.Uuid

  blocker User @relation("blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@id([blockerId, blockedId])
  @@map("blocks")
}

model Conversation {
  id         String    @id @default(uuid()) @db.Uuid
  partnerAId String    @map("partner_a_id") @db.Uuid
  partnerBId String    @map("partner_b_id") @db.Uuid
  isDeleted  Boolean   @default(false) @map("is_deleted")
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz

  partnerA User @relation("partnerA", fields: [partnerAId], references: [id], onDelete: Cascade)
  partnerB User @relation("partnerB", fields: [partnerBId], references: [id], onDelete: Cascade)

  messages Message[]

  @@unique([partnerAId, partnerBId])
  @@map("conversations")
}

model Message {
  id           String    @id @default(uuid()) @db.Uuid
  conversationId String  @map("conversation_id") @db.Uuid
  senderId     String    @map("sender_id") @db.Uuid
  receiverId   String    @map("receiver_id") @db.Uuid
  content      String?   @db.Text
  isRead       Boolean   @default(false) @map("is_read")
  isDeleted    Boolean   @default(false) @map("is_deleted")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User       @relation("sender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver     User       @relation("receiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@map("messages")
}

model Device {
  id       String   @id @default(uuid()) @db.Uuid
  userId   String   @map("user_id") @db.Uuid
  devtype  Int      @default(0)
  devToken String   @map("dev_token") @db.VarChar

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, devToken])
  @@map("devices")
}

model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  type      String?  @db.VarChar
  objectId  String?  @map("object_id") @db.Uuid
  title     String?  @db.VarChar
  avatar    String?  @db.VarChar
  groupType Int      @default(0) @map("group_type")
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model PushSetting {
  userId          String   @id @map("user_id") @db.Uuid
  likeComment     Int      @default(1) @map("like_comment")
  fromFriends     Int      @default(1) @map("from_friends")
  requestedFriend Int      @default(1) @map("requested_friend")
  suggestedFriend Int      @default(1) @map("suggested_friend")
  birthday        Int      @default(1)
  video           Int      @default(1)
  report          Int      @default(1)
  soundOn         Int      @default(1) @map("sound_on")
  notificationOn  Int      @default(1) @map("notification_on")
  vibrantOn       Int      @default(1) @map("vibrant_on")
  ledOn           Int      @default(1) @map("led_on")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("push_settings")
}

model Post {
  id           String    @id @default(uuid()) @db.Uuid
  ownerId      String    @map("owner_id") @db.Uuid
  content      String    @db.Text
  media        String[]  @db.VarChar
  hashtags     String[]  @db.VarChar @default([])
  commentIds   String[]  @map("comment_ids") @db.Uuid @default([])
  likeIds      String[]  @map("like_ids") @db.Uuid @default([])
  courseId     String?   @map("course_id") @db.Uuid
  exerciseId   String?   @map("exercise_id") @db.Uuid
  deviceMaster String    @map("device_master") @db.Uuid
  deviceSlave  String?   @map("device_slave") @db.Uuid
  leftVideo    String?   @map("left_video") @db.VarChar
  rightVideo   String?   @map("right_video") @db.VarChar
  isLocked     Boolean   @default(false) @map("is_locked")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  owner    User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  comments Comment[]
  reports  Report[]

  @@map("posts")
}

model Comment {
  id             String   @id @default(uuid()) @db.Uuid
  postId         String   @map("post_id") @db.Uuid
  authorId       String   @map("author_id") @db.Uuid
  content        String?  @db.Text
  score          String?
  detailMistakes String?  @map("detail_mistakes") @db.Text
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  author User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@map("comments")
}

model Report {
  id        String   @id @default(uuid()) @db.Uuid
  postId    String   @map("post_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  subject   String   @db.VarChar
  details   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@map("reports")
}

model Enrollment {
  id        String   @id @default(uuid()) @db.Uuid
  studentId String   @map("student_id") @db.Uuid
  teacherId String   @map("teacher_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  student User @relation("student_enrollments", fields: [studentId], references: [id], onDelete: Cascade)
  teacher User @relation("teacher_enrollments", fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([studentId, teacherId])
  @@map("enrollments")
}

model EnrollmentRequest {
  id        String   @id @default(uuid()) @db.Uuid
  studentId String   @map("student_id") @db.Uuid
  teacherId String   @map("teacher_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  student User @relation("student_requests", fields: [studentId], references: [id], onDelete: Cascade)
  teacher User @relation("teacher_requests", fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([studentId, teacherId])
  @@map("enrollment_requests")
}

model VerifyCode {
  id         String   @id @default(uuid()) @db.Uuid
  phonenumber String  @db.VarChar
  code       String   @db.VarChar(6)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("verify_codes")
}

model SearchHistory {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  keyword     String   @db.VarChar
  durationMin String?  @map("duration_min") @db.VarChar
  durationMax String?  @map("duration_max") @db.VarChar
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("search_histories")
}
